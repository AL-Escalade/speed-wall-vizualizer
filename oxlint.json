{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error",
    "pedantic": "error",
    "style": "error"
  },
  "rules": {
    "max-lines-per-function": "off",
    "max-lines": "off",
    "max-depth": "off",
    "no-inline-comments": "off",
    "require-await": "off",
    "no-magic-numbers": "off",
    "sort-keys": "off",
    "id-length": "off",
    "sort-imports": "off",
    "func-style": "off",
    "no-ternary": "off",
    "curly": "off",
    "max-statements": "off",
    "capitalized-comments": "off",
    "init-declarations": "off",
    "arrow-body-style": "off",
    "max-params": "off",
    "no-continue": "off",
    "no-nested-ternary": "off",
    "new-cap": "off"
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "coverage",
    "*.config.js",
    "*.config.ts"
  ]
}
